#!/usr/bin/env bash
set -e

ORIGIN=$(pwd)
BASE="scripts/packages"

source "$(dirname "$0")/version"

DOCKER=$(command -v docker 2>/dev/null || command -v podman 2>/dev/null || true)

if [ -z "${DOCKER}" ]; then
	echo "build-packages: docker or podman is required" >&2
	exit 1
fi

for i in "${BASE}"/*/; do
	PLATFORM=$(basename "${i}")
	echo "build-packages: Building ${PLATFORM}"

	cd "${ORIGIN}/${i}"

	if [ ! -f "Dockerfile" ]; then
		echo "build-packages: WARN: Skipping ${PLATFORM} (no Dockerfile)"
		continue
	fi

	if [ -x "prebuild.sh" ]; then
		./prebuild.sh
	fi

	IMAGE="hbm-pkg-${PLATFORM}"
	OUTDIR="${ORIGIN}/dist/${PLATFORM}"
	mkdir -p "${OUTDIR}"

	"${DOCKER}" build -t "${IMAGE}" .

	"${DOCKER}" run --rm \
		-v "${OUTDIR}:/tmp/dist" \
		"${IMAGE}" "${VERSION}" "${RELEASE}"

	if [ -d "build" ]; then
		rm -rf build
	fi

	"${DOCKER}" rmi "${IMAGE}" >/dev/null 2>&1 || true
done

echo "build-packages: DONE"
echo "build-packages: Packages in ${ORIGIN}/dist/"
find "${ORIGIN}/dist" -type f | sort
